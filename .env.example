# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .env before running docker compose:
#   cp .env.example .env
# .env is gitignored and never committed. This file is safe to commit.
# ─────────────────────────────────────────────────────────────────────────────

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_DB=wms
DB_USERNAME=wms
DB_PASSWORD=wms
POSTGRES_PORT=5432

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_PASSWORD=
REDIS_PORT=6379

# ── Kafka ─────────────────────────────────────────────────────────────────────
# 9093 = host-accessible port (tools on your laptop)
# 9092 = internal container port (used by the app — never change this)
KAFKA_PORT=9093

# ── JWT ───────────────────────────────────────────────────────────────────────
# MUST be replaced before any non-local deployment.
# Minimum 256 bits (32 chars) for HMAC-SHA256.
JWT_SECRET=dev-only-secret-change-before-any-real-deployment-256bits!!
JWT_EXPIRATION_MS=86400000

# ── App ───────────────────────────────────────────────────────────────────────
SERVER_PORT=8080
